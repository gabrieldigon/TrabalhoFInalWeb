<div class="row">
    <div class="col-lg-8 mx-auto">
        <!-- Menu Screen -->
        <div id="menu-screen">
            <div class="card">
                <div class="card-body text-center">
                    <h1 class="display-4 mb-3">🏆 Wordle Copa 2026</h1>
                    <p class="lead mb-4">Adivinhe as seleções da Copa do Mundo!</p>
                    
                    <div class="mb-3">
                        <button class="btn btn-outline-secondary btn-lg" id="difficulty-select" data-value="medium">
                            Dificuldade: Médio
                        </button>
                    </div>
                    
                    <div class="mb-3">
                        <button class="btn btn-primary btn-lg" id="start-btn">🎮 Jogar</button>
                    </div>
                    
                    <div class="d-flex justify-content-center gap-3">
                        <button class="btn btn-outline-dark" id="sound-btn">🔊</button>
                        <button class="btn btn-outline-info" id="history-btn">📊 Histórico</button>
                    </div>
                    
                    <div class="mt-3">
                        <small class="text-muted">Recorde: <span id="high-score-display">0</span></small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Game Screen -->
        <div id="game-screen" class="hidden">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <span class="badge bg-primary fs-6" id="phase-display">Fase 1</span>
                            <span class="badge bg-danger fs-6 ms-2" id="lives-display">❤️❤️❤️</span>
                        </div>
                        <div>
                            <span class="fw-bold" id="score-display">Pontos: 0</span>
                        </div>
                        <div>
                            <button class="btn btn-sm btn-outline-secondary" id="game-sound-btn">🔊</button>
                            <button class="btn btn-sm btn-outline-warning" id="pause-btn">⏸️</button>
                        </div>
                    </div>

                    <div id="message-display" class="message hidden"></div>

                    <div id="powerups-display" class="text-center mb-3"></div>

                    <div id="grid-container" class="grid-container mb-3"></div>

                    <div id="keyboard-container" class="keyboard-container"></div>

                    <div id="hint-display" class="text-center text-muted mt-2 hidden"></div>
                </div>
            </div>
        </div>

        <!-- Game Over Screen -->
        <div id="gameover-screen" class="hidden">
            <div class="card">
                <div class="card-body text-center">
                    <h2 id="gameover-title">🎉 Parabéns!</h2>
                    <p class="display-6" id="final-score-display">Pontuação Final: 0</p>
                    <p class="lead" id="last-word-display">Palavra: </p>
                    <p class="text-info" id="high-score-display">Recorde: 0</p>
                    
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <button class="btn btn-primary btn-lg" id="restart-btn">🔄 Jogar Novamente</button>
                        <button class="btn btn-secondary btn-lg" id="menu-btn">🏠 Menu</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pause Overlay -->
        <div id="pause-overlay" class="pause-overlay hidden">
            <div class="pause-modal">
                <h2>⏸️ Jogo Pausado</h2>
                <div class="d-flex justify-content-center gap-3 mt-4">
                    <button class="btn btn-primary btn-lg" id="resume-btn">▶️ Continuar</button>
                    <button class="btn btn-danger btn-lg" id="quit-btn">🚪 Sair</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/words.js"></script>
<script src="/js/storage.js"></script>
<script src="/js/sound.js"></script>
<script src="/js/player.js"></script>
<script src="/js/keyboard.js"></script>
<script src="/js/ui.js"></script>
<script src="/js/game-logic.js"></script>
<script src="/js/main.js"></script>