<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h3 class="mb-0">Cursos Cadastrados</h3>
            </div>
            <div class="card-body">
                <form action="/majors" method="POST" class="mb-4">
                    <div class="input-group">
                        <input type="text" class="form-control" name="name" placeholder="Nome do curso" required>
                        <button type="submit" class="btn btn-primary">Adicionar</button>
                    </div>
                </form>

                <table class="table table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each majors}}
                        <tr>
                            <td>{{this.id}}</td>
                            <td>{{this.name}}</td>
                            <td>
                                <button class="btn btn-danger btn-sm" onclick="confirmDelete({{this.id}}, '{{this.name}}')">
                                    Excluir
                                </button>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmação -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmar Exclusão</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Tem certeza que deseja excluir o curso <strong id="majorName"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Excluir</button>
            </div>
        </div>
    </div>
</div>

<script>
let deleteMajorId = null;

function confirmDelete(id, name) {
    deleteMajorId = id;
    document.getElementById('majorName').textContent = name;
    const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
    modal.show();
}

document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
    if (deleteMajorId) {
        fetch('/majors/delete/' + deleteMajorId, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Erro ao excluir curso');
            }
        })
        .catch(() => alert('Erro ao excluir curso'));
    }
});
</script>